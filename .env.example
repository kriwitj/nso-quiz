# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 24
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_password
POSTGRES_DB=quizdb

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 24
# Leave empty to disable Redis password (not recommended in production)
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32   (must be ≥ 32 chars)
JWT_SECRET=change-me-super-secret-jwt-key-32chars-min
JWT_EXPIRES_IN=15m
# Generate: openssl rand -hex 32
JWT_REFRESH_SECRET=change-me-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Development:   http://localhost:4000/api/auth/google/callback
# Production:    https://province-stat.nso.go.th/nso-quiz/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ── MinIO (S3-compatible storage) ─────────────────────────────────────────────
# ACCESS_KEY = username (min 3 chars)
MINIO_ACCESS_KEY=minioadmin
# Generate: openssl rand -base64 24   (min 8 chars)
MINIO_SECRET_KEY=changeme_minio_secret
MINIO_BUCKET=quiz-assets
# URL that browsers use to load uploaded images
# Development: http://localhost:9000
# Production:  https://province-stat.nso.go.th:9000  (or CDN URL)
MINIO_PUBLIC_URL=http://localhost:9000

# ── Next.js / NextAuth ────────────────────────────────────────────────────────
# NEXTAUTH_URL must include BASE_PATH in production
# Development: http://localhost:3000
# Production:  https://province-stat.nso.go.th/nso-quiz
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=change-me-nextauth-secret-key
# Development: http://localhost:4000/api
# Production:  https://province-stat.nso.go.th/nso-quiz/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Development: http://localhost:4000   (host only, no path)
# Production:  https://province-stat.nso.go.th
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ── App URLs ──────────────────────────────────────────────────────────────────
# Development: http://localhost:3000
# Production:  https://province-stat.nso.go.th  (no path — used for CORS)
FRONTEND_URL=http://localhost:3000

# ── Base Path (baked into Next.js bundle at Docker build time) ────────────────
# Set to /nso-quiz for production, leave empty for root deployment.
# Both variables must have the same value.
# Changing requires rebuilding the Docker image: docker compose up -d --build web
BASE_PATH=/nso-quiz
NEXT_PUBLIC_BASE_PATH=/nso-quiz
